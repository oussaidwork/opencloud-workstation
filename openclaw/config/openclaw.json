{
  "$schema": "https://opencode.ai/config.json",
  "gateway": {
    "port": 18789,
    "bind": "loopback",
    "controlUi": {
      "enabled": true
    },
    "mode": "local"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "models": {
    "providers": {
      "opencode": {
        "apiKey": "${OPENCODE_API_KEY}",
        "models": [
          { "id": "deepseek-v4-flash-free", "name": "DeepSeek V4 Flash Free", "maxTokens": 2000 },
          { "id": "mimo-v2.5-free", "name": "Mimo v2.5 Free", "maxTokens": 2000 },
          { "id": "nemotron-3-ultra-free", "name": "Nemotron 3 Ultra Free", "maxTokens": 2000 },
          { "id": "north-mini-code-free", "name": "North Mini Code Free", "maxTokens": 2000 }
        ]
      },
      "google": {
        "apiKey": "${GEMINI_API_KEY}"
      },
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "models": [
          {
            "id": "openrouter/free",
            "name": "OpenRouter Free (auto)",
            "contextWindow": 128000,
            "maxTokens": 8192,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
          },
          {
            "id": "deepseek/deepseek-v4-flash",
            "name": "DeepSeek V4 Flash",
            "contextWindow": 65536,
            "maxTokens": 8192,
            "input": ["text"],
            "cost": { "input": 9e-8, "output": 1.8e-7, "cacheRead": 0, "cacheWrite": 0 }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "$HOME/workspace",
      "model": {
        "primary": "opencode/deepseek-v4-flash-free"
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "identity": {
          "name": "DevBot",
          "theme": "coding assistant with OpenCode integration",
          "emoji": "💻"
        },
        "tools": {
          "exec": {
            "timeoutSec": 1800
          }
        },
        "description": "I am a coding assistant. For simple conversation, I answer directly. For coding tasks (implement, fix, refactor, review, test, deploy), I use the exec tool to run \"opencode-run <task>\" in ~/workspace to leverage OpenCode CLI capabilities for file editing, git, Docker, and testing."
      }
    ]
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "plugins": {
    "entries": {
      "opencode": { "enabled": true },
      "openrouter": { "enabled": true }
    }
  },
  "skills": {
    "entries": {
      "projects": { "enabled": true }
    }
  },
  "commands": {
    "ownerAllowFrom": []
  }
}
