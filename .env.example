# === Required ===

# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# OpenCode API key (get from https://opencode.ai/auth)
# Primary provider — free models included
OPENCODE_API_KEY=

# code-server web UI password
CODE_SERVER_PASSWORD=changeme

# === Optional (fallback providers) ===

# Google Gemini API key (free tier, get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# OpenRouter API key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# === Git config (optional) ===
# GIT_USER_NAME=DevBot
# GIT_USER_EMAIL=devbot@example.com

# === SSH agent (optional, for private git repos) ===
# SSH agent socket is auto-forwarded from host if running.
# Or mount your .ssh directory by uncommenting in docker-compose.yml.

# === Optional ===
# Cloudflare Tunnel token (for public access via tunnel)
CLOUDFLARE_TUNNEL_TOKEN=
