# === Required ===

# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# At least one LLM provider key:
# OpenCode (recommended primary)
OPENCODE_API_KEY=
# OR Google Gemini (free tier)
GEMINI_API_KEY=
# OR OpenRouter
OPENROUTER_API_KEY=

# code-server web UI password
CODE_SERVER_PASSWORD=changeme

# === Optional ===

# Cloudflare Tunnel token (for public access)
CLOUDFLARE_TUNNEL_TOKEN=
